{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "node_modules",
    ".venv",
    "dist",
    "build",
    "coverage",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "*.min.js",
    "*.min.css",
    ".embeddings"
  ],
  "ignorePaths": [
    "docs/plans"
  ],
  "words": [
    "hookify", "hookifies",
    "ollama", "OLLAMA",
    "worktree", "worktrees",
    "nomic", "qwen", "deepseek",
    "sonarcloud", "codety", "megalinter",
    "htmlcov", "htmlcoverage",
    "frontmatter",
    "argjson",
    "softprops",
    "parallelizable",
    "descoping",
    "unwaited",
    "gitleaks",
    "actionlint",
    "yamllint",
    "markdownlint",
    "commitlint",
    "shellcheck",
    "pipx",
    "toolrc",
    "cspell",
    "LICEOF", "SECEOF", "BUGEOF", "FEATEOF",
    "pyproject",
    "pytest", "xdist",
    "mypy", "ruff",
    "tsconfig",
    "Dockerfiles",
    "hostnames",
    "Autobuild", "autobuild",
    "pyupgrade",
    "rhysd",
    "deadcode",
    "lintstagedrc",
    "pacman", "noconfirm",
    "hotspots",
    "Iseconds"
  ],
  "dictionaries": ["typescript", "python", "bash", "npm"],
  "overrides": [
    {
      "filename": "**/*.sh",
      "dictionaries": ["bash"]
    }
  ]
}
