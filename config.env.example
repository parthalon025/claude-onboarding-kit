# claude-onboarding-kit configuration
# Copy to ~/.claude/kit/config.env and edit

# GitHub org or username for repo creation
GITHUB_ORG="your-username"

# Default repo visibility: private or public
DEFAULT_VISIBILITY="private"

# Ollama settings (optional — features degrade gracefully without ollama)
OLLAMA_URL="http://localhost:11434"
OLLAMA_REVIEW_MODEL="qwen2.5-coder:14b"
OLLAMA_EMBED_MODEL="nomic-embed-text"

# Template repos (optional — falls back to inline scaffold if not available)
# Set to your own template repos or leave empty to skip template-based creation
TEMPLATE_NODE_REPO=""
TEMPLATE_PYTHON_REPO=""
